{
  "name": "influenca",
  "type": "module",
  "version": "1.0.1",
  "description": "A starter for creating a TypeScript package.",
  "author": "Author Name <author.name@mail.com>",
  "license": "MIT",
  "homepage": "https://github.com/garyb432/influenca#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/garyb432/influenca.git"
  },
  "bugs": {
    "url": "https://github.com/garyb432/influenca/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "assets",
    "dist"
  ],
  "bin": {
    "influenca": "./dist/index.mjs"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --run",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@eslint/markdown": "^8.0.2",
    "@types/node": "^25.9.3",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "pkg-pr-new": "^0.0.50",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "cac": "^7.0.0",
    "exifreader": "^4.41.0"
  },
  "stackblitz": {
    "startCommand": "pwd && ls -lah fun/pkg-pr-new-smoke/fixtures/media && npx -y . --help"
  }
}
